# Ethical OSINT Tracker — example environment configuration.
# Copy to .env and fill in real values:  cp .env.example .env
# Requires python-dotenv (in requirements.txt) for the app to load this file.
# NEVER commit your real .env — it is gitignored.

# ── Admin bootstrap (first run / password reset only) ─────────────────────────
# Required by reset_admin.py and by start.sh on a brand-new database.
# Minimum 8 characters. The admin username is always "admin".
ADMIN_PASSWORD=change-me-min-8-chars

# ── Flask session signing key ─────────────────────────────────────────────────
# Set a fixed, long random value. If this changes between restarts, all sessions
# are invalidated (you get logged out). Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ── API key encryption at rest ────────────────────────────────────────────────
# Fernet key used to encrypt stored third-party API keys. If unset, keys are
# stored UNENCRYPTED and a warning is logged. Keep this stable — rotating it makes
# previously-stored API keys undecryptable. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
API_KEYS_FERNET_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
# Defaults to local SQLite if unset.
# DB_URL=sqlite:///./dev.db
# DB_URL=mysql+pymysql://user:password@localhost/osint_tracker

# ── Optional behaviour toggles ────────────────────────────────────────────────
# Allow public self-registration (rate-limited). Off by default. Must be "true".
REGISTRATION_ENABLED=false
# Delete investigations older than this many days (0 disables the purge job).
RETENTION_DAYS=90
# Max entries in the in-memory service cache (LRU eviction).
CACHE_MAX_SIZE=1000

# ── Dev server (run.py) — never enable debug in production ─────────────────────
# FLASK_DEV=1        # use the Werkzeug dev server via start.sh instead of gunicorn
# FLASK_DEBUG=1      # enable debug mode (DEV ONLY)
# FLASK_HOST=127.0.0.1
# FLASK_PORT=3000
